    "multer": "^1.4.5-lts.1",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
